generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model booking_checklist_items {
  id                          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_service_id          String                       @db.Uuid
  template_id                 String?                      @db.Uuid
  title                       String                       @db.VarChar(255)
  status                      checklist_item_status?       @default(PENDING)
  note                        String?
  completed_at                DateTime?                    @db.Timestamp(6)
  created_at                  DateTime?                    @default(now()) @db.Timestamp(6)
  booking_services            booking_services             @relation(fields: [booking_service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service_checklist_templates service_checklist_templates? @relation(fields: [template_id], references: [id], onUpdate: NoAction)
}

model booking_media {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id  String     @db.Uuid
  uploaded_by String     @db.Uuid
  media_url   String
  media_type  media_type
  caption     String?
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  bookings    bookings   @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       User       @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model booking_status_logs {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id String          @db.Uuid
  old_status booking_status?
  new_status booking_status
  changed_by String?         @db.Uuid
  note       String?
  created_at DateTime?       @default(now()) @db.Timestamp(6)
  bookings   bookings        @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User?           @relation(fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model bookings {
  id                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                  String                 @db.Uuid
  provider_id                  String?                @db.Uuid
  address_id                   String                 @db.Uuid
  requested_slot_id            String                 @db.Uuid
  provider_working_slot_id     String?                @db.Uuid
  requested_date               DateTime               @db.Date
  service_duration_minutes     Int
  travel_duration_minutes      Int                    @default(0)
  buffer_minutes               Int                    @default(0)
  estimated_start_at           DateTime               @db.Timestamp(6)
  estimated_end_at             DateTime               @db.Timestamp(6)
  status                       booking_status         @default(PENDING_PAYMENT)
  total_price                  Decimal                @default(0) @db.Decimal(12, 2)
  customer_note                String?
  provider_note                String?
  cancellation_reason          String?
  accepted_at                  DateTime?              @db.Timestamp(6)
  started_at                   DateTime?              @db.Timestamp(6)
  completed_at                 DateTime?              @db.Timestamp(6)
  cancelled_at                 DateTime?              @db.Timestamp(6)
  created_at                   DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                   DateTime?              @default(now()) @db.Timestamp(6)
  address_snapshot             Json?
  cancellation_policy_snapshot Json?
  price_snapshot               Json?
  cancelled_by                 String?                @db.Uuid
  cancellation_requested_by    String?                @db.Uuid
  customer_confirmed_at        DateTime?              @db.Timestamp(6)
  completion_requested_at      DateTime?              @db.Timestamp(6)
  booking_media                booking_media[]
  booking_status_logs          booking_status_logs[]
  customer_addresses           customer_addresses     @relation(fields: [address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                        User                   @relation("customer_bookings", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cancelled_by_user            User?                  @relation("cancelled_bookings", fields: [cancelled_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cancellation_requested_by_user User?                 @relation("cancellation_requested_bookings", fields: [cancellation_requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider_profiles            provider_profiles?     @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  time_slots                   time_slots             @relation(fields: [requested_slot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider_working_slots       provider_working_slots? @relation(fields: [provider_working_slot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  booking_pets                 booking_pets[]
  chat_rooms                   chat_rooms?
  complaints                   complaints[]
  notifications                notifications[]
  payments                     payments?
  reviews                      reviews[]
  booking_events               booking_events[]
  booking_cancellations        booking_cancellations[]

  @@index([requested_date], map: "idx_bookings_requested_date")
  @@index([customer_id], map: "idx_bookings_customer_id")
  @@index([provider_id], map: "idx_bookings_provider_id")
  @@index([provider_id, requested_date, estimated_start_at, estimated_end_at], map: "idx_bookings_schedule_conflict", where: raw("(status = ANY (ARRAY['ACCEPTED'::booking_status, 'IN_PROGRESS'::booking_status, 'PENDING_PROVIDER_ACCEPTANCE'::booking_status, 'AWAITING_CUSTOMER_CONFIRMATION'::booking_status]))"))
  @@index([status], map: "idx_bookings_status")
}

model chat_messages {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_room_id String       @db.Uuid
  sender_id    String       @db.Uuid
  message_type message_type @default(TEXT)
  content      String?
  media_url    String?
  is_read      Boolean?     @default(false)
  created_at   DateTime?    @default(now()) @db.Timestamp(6)
  chat_rooms   chat_rooms   @relation(fields: [chat_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        User         @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([chat_room_id], map: "idx_chat_messages_room_id")
}

model chat_rooms {
  id                                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id                               String          @unique @db.Uuid
  customer_id                              String          @db.Uuid
  provider_user_id                         String          @db.Uuid
  is_active                                Boolean?        @default(true)
  created_at                               DateTime?       @default(now()) @db.Timestamp(6)
  chat_messages                            chat_messages[]
  bookings                                 bookings        @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_chat_rooms_customer_idTousers      User            @relation("chat_rooms_customer_idTousers", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_chat_rooms_provider_user_idTousers User            @relation("chat_rooms_provider_user_idTousers", fields: [provider_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model complaint_evidences {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_id String      @db.Uuid
  uploaded_by  String      @db.Uuid
  file_url     String
  media_type   media_type?
  description  String?
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  complaints   complaints  @relation(fields: [complaint_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        User        @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model complaints {
  id                                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id                             String                @db.Uuid
  complainant_id                         String                @db.Uuid
  accused_id                             String?               @db.Uuid
  title                                  String                @db.VarChar(255)
  description                            String
  status                                 complaint_status?     @default(OPEN)
  admin_id                               String?               @db.Uuid
  resolution_note                        String?
  resolved_at                            DateTime?             @db.Timestamp(6)
  created_at                             DateTime?             @default(now()) @db.Timestamp(6)
  updated_at                             DateTime?             @default(now()) @db.Timestamp(6)
  reason                                 dispute_reason?
  decision                               dispute_decision?
  decided_at                             DateTime?             @db.Timestamp(6)
  admin_note                             String?
  complaint_evidences                    complaint_evidences[]
  users_complaints_accused_idTousers     User?                 @relation("complaints_accused_idTousers", fields: [accused_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_complaints_admin_idTousers       User?                 @relation("complaints_admin_idTousers", fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bookings                               bookings              @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_complaints_complainant_idTousers User                  @relation("complaints_complainant_idTousers", fields: [complainant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_complaints_status")
}

model customer_addresses {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String     @db.Uuid
  label         String?    @db.VarChar(100)
  receiver_name String?    @db.VarChar(100)
  phone         String?    @db.VarChar(20)
  address_line  String
  ward          String?    @db.VarChar(100)
  district      String?    @db.VarChar(100)
  city          String?    @db.VarChar(100)
  latitude      Decimal?   @db.Decimal(10, 7)
  longitude     Decimal?   @db.Decimal(10, 7)
  is_default    Boolean?   @default(false)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  bookings      bookings[]
  users         User       @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notifications {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String            @db.Uuid
  type               notification_type
  title              String            @db.VarChar(255)
  content            String?
  related_booking_id String?           @db.Uuid
  is_read            Boolean?          @default(false)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  bookings           bookings?         @relation(fields: [related_booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_read], map: "idx_notifications_is_read")
  @@index([user_id], map: "idx_notifications_user_id")
}

model payments {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id        String             @unique @db.Uuid
  customer_id       String             @db.Uuid
  provider_id       String?            @db.Uuid
  amount            Decimal            @db.Decimal(12, 2)
  platform_fee      Decimal?           @default(0) @db.Decimal(12, 2)
  provider_amount   Decimal?           @default(0) @db.Decimal(12, 2)
  method            payment_method
  status            payment_status     @default(PENDING)
  transaction_code  String?            @db.VarChar(255)
  paid_at           DateTime?          @db.Timestamp(6)
  released_at       DateTime?          @db.Timestamp(6)
  refunded_at       DateTime?          @db.Timestamp(6)
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  bookings          bookings           @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             User               @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider_profiles provider_profiles? @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pets {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String         @db.Uuid
  name          String         @db.VarChar(100)
  species       String         @db.VarChar(50)
  breed         String?        @db.VarChar(100)
  age           Int?
  weight        Decimal?       @db.Decimal(5, 2)
  gender        String?        @db.VarChar(20)
  health_note   String?
  behavior_note String?
  avatar_url    String?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  updated_at    DateTime?      @default(now()) @db.Timestamp(6)
  booking_pets  booking_pets[]
  users         User           @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "idx_pets_customer_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model provider_availability {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String            @db.Uuid
  day_of_week       Int               @db.SmallInt
  start_time        DateTime          @db.Time(6)
  end_time          DateTime          @db.Time(6)
  is_available      Boolean?          @default(true)
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  provider_profiles provider_profiles @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([provider_id], map: "idx_provider_availability_provider_id")
}

model provider_profiles {
  id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String                  @unique @db.Uuid
  provider_type            provider_type
  bio                      String?
  experience_years         Int?                    @default(0)
  identity_card_url        String?
  certificate_url          String?
  service_area             String?
  base_location            String?
  status                   provider_status         @default(DRAFT)
  kyc_status               provider_document_status @default(PENDING)
  credential_status        provider_document_status @default(PENDING)
  screening_status         screening_status        @default(NOT_REQUIRED)
  rating_avg               Decimal?                @default(0) @db.Decimal(3, 2)
  total_reviews            Int?                    @default(0)
  total_completed_bookings Int?                    @default(0)
  created_at               DateTime?               @default(now()) @db.Timestamp(6)
  updated_at               DateTime?               @default(now()) @db.Timestamp(6)
  bookings                 bookings[]
  payments                 payments[]
  provider_availability    provider_availability[]
  users                    User                    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  provider_services        provider_services[]
  provider_working_days    provider_working_days[]
  provider_documents       provider_documents[]
  provider_service_areas   provider_service_areas[]
  provider_trust_badges    provider_trust_badges[]

  @@index([status], map: "idx_provider_profiles_status")
  @@index([provider_type], map: "idx_provider_profiles_type")
  @@index([user_id], map: "idx_provider_profiles_user_id")
}

model provider_services {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id        String            @db.Uuid
  service_id         String            @db.Uuid
  price              Decimal           @db.Decimal(12, 2)
  custom_description String?
  is_active          Boolean?          @default(true)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  pet_species        String            @default("Dog") @db.VarChar(50)
  min_weight         Decimal           @default(0) @db.Decimal(5, 2)
  max_weight         Decimal           @default(100) @db.Decimal(5, 2)
  status             capability_status @default(PENDING)
  approved_by        String?           @db.Uuid
  approved_at        DateTime?         @db.Timestamp(6)
  reject_reason      String?
  updated_at         DateTime?         @default(now()) @db.Timestamp(6)
  booking_services   booking_services[]
  provider_profiles  provider_profiles @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services           services          @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approver           User?             @relation("approved_capabilities", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([provider_id, service_id, pet_species, min_weight, max_weight])
  @@index([provider_id], map: "idx_provider_services_provider_id")
  @@index([service_id], map: "idx_provider_services_service_id")
}

model reviews {
  id                               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id                       String        @db.Uuid
  reviewer_id                      String        @db.Uuid
  reviewee_id                      String        @db.Uuid
  rating                           Int           @db.SmallInt
  comment                          String?
  created_at                       DateTime?     @default(now()) @db.Timestamp(6)
  is_hidden                        Boolean       @default(false)
  hidden_reason                    String?
  hidden_by                        String?       @db.Uuid
  hidden_at                        DateTime?     @db.Timestamp(6)
  bookings                         bookings      @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_reviews_reviewee_idTousers User          @relation("reviews_reviewee_idTousers", fields: [reviewee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_reviews_reviewer_idTousers User          @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hidden_by_user                   User?         @relation("reviews_hidden_byTousers", fields: [hidden_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review_media                     review_media[]

  @@unique([booking_id, reviewer_id, reviewee_id])
}

model service_checklist_templates {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id              String                    @db.Uuid
  title                   String                    @db.VarChar(255)
  description             String?
  is_required             Boolean?                  @default(true)
  sort_order              Int?                      @default(0)
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  booking_checklist_items booking_checklist_items[]
  services                services                  @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model services {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String                        @db.VarChar(150)
  description                 String?
  category                    String?                       @db.VarChar(100)
  base_price                  Decimal                       @default(0) @db.Decimal(12, 2)
  duration_minutes            Int                           @default(60)
  is_active                   Boolean?                      @default(true)
  cancellation_policy_id      String?                       @db.Uuid
  created_at                  DateTime?                     @default(now()) @db.Timestamp(6)
  provider_services           provider_services[]
  service_checklist_templates service_checklist_templates[]
  pricing_rules               service_pricing_rules[]
  cancellation_policy         cancellation_policies?        @relation(fields: [cancellation_policy_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model User {
  id                                            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName                                      String                @map("full_name") @db.VarChar(100)
  email                                         String                @unique @db.VarChar(150)
  phone                                         String?               @db.VarChar(20)
  passwordHash                                  String?               @map("password_hash")
  supabaseId                                    String?               @unique @map("supabase_id") @db.Uuid
  emailVerifiedAt                               DateTime?             @map("email_verified_at") @db.Timestamp(6)
  avatarUrl                                     String?               @map("avatar_url")
  role                                          Role                  @default(CUSTOMER)
  isActive                                      Boolean               @default(true) @map("is_active")
  status                                        user_status           @default(ACTIVE)
  suspended_reason                              String?
  suspended_at                                  DateTime?             @db.Timestamp(6)
  createdAt                                     DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                                     DateTime?             @default(now()) @map("updated_at") @db.Timestamp(6)
  booking_media                                 booking_media[]
  booking_status_logs                           booking_status_logs[]
  bookings                                      bookings[]            @relation("customer_bookings")
  cancelled_bookings                            bookings[]            @relation("cancelled_bookings")
  cancellation_requested_bookings               bookings[]            @relation("cancellation_requested_bookings")
  chat_messages                                 chat_messages[]
  chat_rooms_chat_rooms_customer_idTousers      chat_rooms[]          @relation("chat_rooms_customer_idTousers")
  chat_rooms_chat_rooms_provider_user_idTousers chat_rooms[]          @relation("chat_rooms_provider_user_idTousers")
  complaint_evidences                           complaint_evidences[]
  complaints_complaints_accused_idTousers       complaints[]          @relation("complaints_accused_idTousers")
  complaints_complaints_admin_idTousers         complaints[]          @relation("complaints_admin_idTousers")
  complaints_complaints_complainant_idTousers   complaints[]          @relation("complaints_complainant_idTousers")
  customer_addresses                            customer_addresses[]
  notifications                                 notifications[]
  payments                                      payments[]
  pets                                          pets[]
  provider_profiles                             provider_profiles?
  refresh_tokens                                refresh_tokens[]
  reviews_reviews_reviewee_idTousers            reviews[]             @relation("reviews_reviewee_idTousers")
  reviews_reviews_reviewer_idTousers            reviews[]             @relation("reviews_reviewer_idTousers")
  reviews_reviews_hidden_byTousers              reviews[]             @relation("reviews_hidden_byTousers")
  provider_documents_reviewed                   provider_documents[]  @relation("reviewed_documents")
  approved_capabilities                         provider_services[]   @relation("approved_capabilities")
  booking_events                                booking_events[]
  booking_cancellations_requested               booking_cancellations[] @relation("requested_cancellations")
  booking_cancellations_reviewed                booking_cancellations[] @relation("reviewed_cancellations")
  support_tickets_user                          support_tickets[]     @relation("user_tickets")
  support_tickets_assigned                      support_tickets[]     @relation("assigned_tickets")
  support_ticket_messages                       support_ticket_messages[]
  granted_badges                                provider_trust_badges[] @relation("granted_badges")
  audit_logs                                    audit_logs[]

  @@index([role], map: "idx_users_role")
  @@map("users")
}

model provider_documents {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id   String                   @db.Uuid
  document_type provider_document_type
  file_url      String
  status        provider_document_status @default(PENDING)
  issued_at     DateTime?                @db.Timestamp(6)
  expired_at    DateTime?                @db.Timestamp(6)
  reviewed_by   String?                  @db.Uuid
  reviewed_at   DateTime?                @db.Timestamp(6)
  reject_reason String?
  note          String?
  created_at    DateTime                 @default(now()) @db.Timestamp(6)
  updated_at    DateTime                 @default(now()) @updatedAt @db.Timestamp(6)

  provider_profiles provider_profiles @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  reviewer          User?             @relation("reviewed_documents", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model provider_service_areas {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String   @db.Uuid
  city        String   @db.VarChar(100)
  district    String   @db.VarChar(100)
  ward        String   @db.VarChar(100)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  provider_profiles provider_profiles @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, city, district, ward])
}

model service_pricing_rules {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id       String    @db.Uuid
  pet_species      String    @db.VarChar(50)
  min_weight       Decimal?  @db.Decimal(5, 2)
  max_weight       Decimal?  @db.Decimal(5, 2)
  price            Decimal   @db.Decimal(12, 2)
  duration_minutes Int
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  services services @relation(fields: [service_id], references: [id], onDelete: Cascade)
}

model cancellation_policies {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(100)
  description String?
  rules_json  Json
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  services    services[]
}

model booking_events {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id String             @db.Uuid
  actor_id   String?            @db.Uuid
  event_type booking_event_type
  note       String?
  metadata   Json?
  created_at DateTime           @default(now()) @db.Timestamp(6)

  bookings bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model booking_cancellations {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id      String              @db.Uuid
  requested_by    String              @db.Uuid
  reason          String
  note            String?
  status          cancellation_status @default(PENDING)
  policy_snapshot Json?
  refund_amount   Decimal?            @db.Decimal(12, 2)
  penalty_amount  Decimal?            @db.Decimal(12, 2)
  reviewed_by     String?             @db.Uuid
  reviewed_at     DateTime?           @db.Timestamp(6)
  created_at      DateTime            @default(now()) @db.Timestamp(6)

  bookings  bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  requester User     @relation("requested_cancellations", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer  User?    @relation("reviewed_cancellations", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model support_tickets {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String                 @db.Uuid
  category          support_ticket_category
  title             String                 @db.VarChar(255)
  description       String
  status            support_ticket_status  @default(OPEN)
  assigned_admin_id String?                @db.Uuid
  resolved_at       DateTime?              @db.Timestamp(6)
  created_at        DateTime               @default(now()) @db.Timestamp(6)
  updated_at        DateTime               @default(now()) @updatedAt @db.Timestamp(6)

  user                    User                      @relation("user_tickets", fields: [user_id], references: [id], onDelete: Cascade)
  admin                   User?                     @relation("assigned_tickets", fields: [assigned_admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  support_ticket_messages support_ticket_messages[]
}

model support_ticket_messages {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id  String   @db.Uuid
  sender_id  String   @db.Uuid
  content    String
  created_at DateTime @default(now()) @db.Timestamp(6)

  support_tickets support_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender          User            @relation(fields: [sender_id], references: [id], onDelete: Cascade)
}

model trust_badges {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String                  @unique @db.VarChar(50)
  name                  String                  @db.VarChar(100)
  description           String?
  is_active             Boolean                 @default(true)
  provider_trust_badges provider_trust_badges[]
}

model provider_trust_badges {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String    @db.Uuid
  badge_id    String    @db.Uuid
  granted_by  String?   @db.Uuid
  granted_at  DateTime  @default(now()) @db.Timestamp(6)
  revoked_at  DateTime? @db.Timestamp(6)
  reason      String?

  provider_profiles provider_profiles @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  trust_badges      trust_badges      @relation(fields: [badge_id], references: [id], onDelete: Cascade)
  granter           User?             @relation("granted_badges", fields: [granted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([provider_id, badge_id])
}

model audit_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id    String?   @db.Uuid
  action      String    @db.VarChar(100)
  target_type String    @db.VarChar(100)
  target_id   String?   @db.Uuid
  old_value   Json?
  new_value   Json?
  reason      String?
  ip_address  String?   @db.VarChar(45)
  user_agent  String?
  created_at  DateTime  @default(now()) @db.Timestamp(6)

  actor User? @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model review_media {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  review_id  String     @db.Uuid
  media_url  String
  media_type media_type
  created_at DateTime   @default(now()) @db.Timestamp(6)

  reviews reviews @relation(fields: [review_id], references: [id], onDelete: Cascade)
}

model refresh_tokens {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  token_hash     String   @unique
  device_info    String?  @db.VarChar(255)
  ip_address     String?  @db.VarChar(45)
  device_id      String?  @db.VarChar(255)
  last_active_at DateTime @default(now()) @db.Timestamp(6)
  expires_at     DateTime @db.Timestamp(6)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  users          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model time_slots {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(50)
  start_time String   @db.VarChar(5)
  end_time   String   @db.VarChar(5)
  slot_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamp(6)

  provider_working_slots provider_working_slots[]
  bookings               bookings[]
}

model provider_working_days {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id  String       @db.Uuid
  work_date    DateTime     @db.Date
  working_mode working_mode @default(FULL_TIME)
  created_at   DateTime?    @default(now()) @db.Timestamp(6)
  updated_at   DateTime?    @default(now()) @db.Timestamp(6)

  provider_profiles      provider_profiles      @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  provider_working_slots provider_working_slots[]

  @@unique([provider_id, work_date])
  @@index([provider_id])
  @@index([work_date])
}

model provider_working_slots {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  working_day_id String                   @db.Uuid
  slot_id        String                   @db.Uuid
  status         availability_slot_status @default(BLOCKED)
  held_until     DateTime?                @db.Timestamp(6)
  reserved_until DateTime?                @db.Timestamp(6)
  created_at     DateTime?                @default(now()) @db.Timestamp(6)
  updated_at     DateTime?                @default(now()) @db.Timestamp(6)

  provider_working_days provider_working_days @relation(fields: [working_day_id], references: [id], onDelete: Cascade)
  time_slots            time_slots            @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  bookings              bookings[]

  @@unique([working_day_id, slot_id])
}

model booking_pets {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id    String   @db.Uuid
  pet_id        String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamp(6)
  pet_name      String?  @db.VarChar(100)
  species       String?  @db.VarChar(50)
  breed         String?  @db.VarChar(100)
  age           Int?
  weight        Decimal? @db.Decimal(5, 2)
  gender        String?  @db.VarChar(20)
  health_note   String?
  behavior_note String?
  avatar_url    String?

  bookings         bookings           @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  pets             pets               @relation(fields: [pet_id], references: [id], onDelete: Restrict)
  booking_services booking_services[]

  @@unique([booking_id, pet_id])
}

model booking_services {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_pet_id      String   @db.Uuid
  provider_service_id String   @db.Uuid
  price               Decimal  @db.Decimal(12, 2)
  duration_minutes    Int
  created_at          DateTime @default(now()) @db.Timestamp(6)
  service_name        String?  @db.VarChar(150)
  service_description String?
  service_category    String?  @db.VarChar(100)

  booking_pets            booking_pets              @relation(fields: [booking_pet_id], references: [id], onDelete: Cascade)
  provider_services       provider_services         @relation(fields: [provider_service_id], references: [id], onDelete: Restrict)
  booking_checklist_items booking_checklist_items[]

  @@unique([booking_pet_id, provider_service_id])
}

