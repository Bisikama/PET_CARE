# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pet_care"
DIRECT_URL="postgresql://postgres:password@localhost:5432/pet_care"

# JWT
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"

# Application
NODE_ENV="development"
PORT=3000
APP_NAME="Pet Care"

# Gmail SMTP
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER="your-gmail@gmail.com"
MAIL_PASS="your-16-character-google-app-password"
MAIL_FROM="Pet Care <your-gmail@gmail.com>"

# Email OTP
EMAIL_OTP_TTL_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
MAIL_OTP_BACKGROUND_PATH=""
